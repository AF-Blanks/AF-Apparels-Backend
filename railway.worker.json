{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "celery -A app.core.celery worker --loglevel=info -Q celery,default,email,quickbooks,pricelist,inventory --concurrency=2",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
